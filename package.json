{
  "name": "zacksimon-dev-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo scaffold for zacksimon.dev + Briefly",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "infra/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "briefly:dev:typecheck": "npm run -w @briefly/infra-cdk typecheck",
    "briefly:dev:synth": "npm run -w @briefly/infra-cdk cdk:synth:dev",
    "briefly:dev:diff": "npm run -w @briefly/infra-cdk cdk:diff:dev",
    "briefly:dev:deploy": "npm run -w @briefly/infra-cdk cdk:deploy:dev",
    "briefly:dev:outputs": "./scripts/briefly/dev-outputs.sh",
    "smoke:deploy": "./scripts/smoke-test.sh",
    "smoke:briefly": "./scripts/smoke/briefly-smoke.sh"
  },
  "devDependencies": {
    "@types/node": "^22.15.12",
    "typescript": "^5.8.3"
  }
}
